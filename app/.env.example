# Supabase proje ayarları (Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth kurulumu:
# 1. Supabase Dashboard > Authentication > Providers > Google'ı etkinleştirin
# 2. Google Cloud Console'da OAuth 2.0 Client ID oluşturun
# 3. Authorized redirect URI olarak Supabase callback URL'ini ekleyin:
#    https://your-project.supabase.co/auth/v1/callback
# 4. Supabase Dashboard > Authentication > URL Configuration:
#    Site URL: http://localhost:3000 (geliştirme) veya production URL'iniz
#    Redirect URLs:
#      http://localhost:3000/**
#      http://127.0.0.1:29272/auth/callback   (masaüstü .exe uygulaması için)
